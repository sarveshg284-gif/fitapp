import tkinter as tk
from tkinter import messagebox

# Create main window
root = tk.Tk()
root.title("To-Do List")
root.geometry("450x500")
root.configure(bg="#f0f8ff")

tasks = []

# Functions
def add_task():
    task = task_entry.get().strip()
    if task == "":
        messagebox.showwarning("Warning", "Please enter a task.")
    else:
        tasks.append(task)
        listbox.insert(tk.END, "⬜ " + task)
        task_entry.delete(0, tk.END)

def delete_task():
    try:
        selected = listbox.curselection()[0]
        listbox.delete(selected)
        tasks.pop(selected)
    except:
        messagebox.showwarning("Warning", "Please select a task.")

def complete_task():
    try:
        selected = listbox.curselection()[0]
        task = tasks[selected]
        listbox.delete(selected)
        listbox.insert(selected, "✅ " + task)
    except:
        messagebox.showwarning("Warning", "Please select a task.")

def clear_tasks():
    if messagebox.askyesno("Clear All", "Delete all tasks?"):
        listbox.delete(0, tk.END)
        tasks.clear()

# Title
title = tk.Label(root,
                 text="TO-DO LIST",
                 font=("Arial", 20, "bold"),
                 bg="#f0f8ff",
                 fg="navy")
title.pack(pady=10)

# Entry
task_entry = tk.Entry(root, font=("Arial", 14), width=30)
task_entry.pack(pady=10)

# Buttons
button_frame = tk.Frame(root, bg="#f0f8ff")
button_frame.pack(pady=10)

add_btn = tk.Button(button_frame,
                    text="Add Task",
                    width=12,
                    bg="green",
                    fg="white",
                    command=add_task)
add_btn.grid(row=0, column=0, padx=5, pady=5)

complete_btn = tk.Button(button_frame,
                         text="Complete",
                         width=12,
                         bg="blue",
                         fg="white",
                         command=complete_task)
complete_btn.grid(row=0, column=1, padx=5, pady=5)

delete_btn = tk.Button(button_frame,
                       text="Delete",
                       width=12,
                       bg="red",
                       fg="white",
                       command=delete_task)
delete_btn.grid(row=1, column=0, padx=5, pady=5)

clear_btn = tk.Button(button_frame,
                      text="Clear All",
                      width=12,
                      bg="orange",
                      fg="white",
                      command=clear_tasks)
clear_btn.grid(row=1, column=1, padx=5, pady=5)

# Listbox
listbox = tk.Listbox(root,
                     font=("Arial", 14),
                     width=35,
                     height=15,
                     selectbackground="skyblue")
listbox.pack(pady=10)

# Run application
root.mainloop()
